FROM golang:1.22-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /dbmigrate-worker ./cmd/worker

FROM alpine:3.19
RUN apk --no-cache add ca-certificates
COPY --from=builder /dbmigrate-worker /usr/local/bin/dbmigrate-worker
RUN mkdir -p /data
ENTRYPOINT ["dbmigrate-worker"]
